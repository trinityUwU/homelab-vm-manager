# HomeLab VM Manager — configuration optionnelle.
# La configuration réelle (SSH, clé Netdata, MOTD, heure du check) se gère
# DEPUIS L'INTERFACE, page Paramètres, et est stockée dans backend/data/settings.json.
# Ce fichier ne sert qu'aux ports si tu veux les changer.

# Port du backend FastAPI (défaut 8420)
BACKEND_PORT=8420

# Port du frontend Vite (défaut 8421)
FRONTEND_PORT=8421
